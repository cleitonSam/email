<!DOCTYPE html>
<% assigns = Map.put(assigns, :conn_or_socket, assigns[:conn] || assigns[:socket]) %>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {csrf_meta_tag()}
    <title>
      {get_meta(
        @conn,
        view_module(@conn),
        view_template(@conn),
        :title,
        gettext("Email Marketing Profissional")
      ) <> " · Fluxo Email MKT"}
    </title>
    <meta property="og:image" content={Routes.static_url(@conn, "/images/og_image.png")} />
    <meta property="og:description" content="Fluxo Email MKT - Email Marketing Profissional" />
    <meta name="twitter:card" content="summary" />
    <link
      phx-track-static
      rel="stylesheet"
      href={Routes.static_path(@conn_or_socket, "/css/app.css")}
    />
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={Routes.static_path(@conn_or_socket, "/js/app.js")}
    >
    </script>
    <style>
      button, .button {
        <%= build_styles(%{"background-color" => @form.settings.submit_bg_color, "color" => @form.settings.submit_text_color}) %>;
      }

      /* Modern form enhancements */
      .contact-form {
        animation: formSlideUp 0.4s ease-out;
      }

      @keyframes formSlideUp {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .contact-form input[type="text"]:focus,
      .contact-form input[type="email"]:focus,
      .contact-form input[type="number"]:focus,
      .contact-form select:focus,
      .contact-form textarea:focus {
        border-color: <%= @form.settings.submit_bg_color || "#0066FF" %> !important;
        box-shadow: 0 0 0 3px <%= @form.settings.submit_bg_color || "#0066FF" %>1a !important;
      }

      .contact-form button[type]:hover {
        filter: brightness(1.08);
      }

      .contact-form button[type]:active {
        filter: brightness(0.95);
      }

      @keyframes ping {
        75%, 100% {
          transform: scale(1.4);
          opacity: 0;
        }
      }

      .animate-ping {
        animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
      }
    </style>
  </head>
  <body
    class="flex flex-col items-center justify-center min-h-screen p-4 md:p-8"
    style={build_styles(%{"background-color" => @form.settings.body_bg_color})}
  >
    <main class="w-full">
      {@inner_content}
    </main>
  </body>
</html>
