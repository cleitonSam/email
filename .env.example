# Fluxo Digital - Email MKT
# Copie este arquivo pra .env.production e preencha os valores reais.
# NUNCA commite o .env.production (já está no .gitignore).

# ===== CORE =====
SECRET_KEY_BASE=                  # gerar com: openssl rand -base64 64
HASHID_SALT=                      # gerar com: openssl rand -base64 32
PORT=4000
LOG_LEVEL=info

# ===== BANCO (Postgres externo) =====
DB_URL=postgres://user:senha@host:porta/database
DB_ENABLE_SSL=false
DB_VERIFY_SSL_HOST=FALSE

# ===== URL pública =====
URL_HOST=emailmkt.exemplo.com.br
URL_PORT=443
URL_SCHEMA=https
URL_PATH=/

# ===== SMTP do sistema (emails de auth, convites) =====
MAILER_TYPE=smtp
MAILER_SMTP_HOST=smtp.provedor.com
MAILER_SMTP_PORT=587
MAILER_SMTP_USER=
MAILER_SMTP_PASSWORD=
MAILER_SMTP_FROM_EMAIL=
MAILER_ENABLE_SSL=false
MAILER_ENABLE_STARTTLS=true

# ===== Features =====
DISABLE_REGISTRATION=true
DISABLE_SENDER_CREATION=false
ENABLE_QUOTAS=false
DISABLE_UPDATE_CHECKS=false
DISABLE_PRECEDENCE_HEADER=false

# ===== ImageKit (galeria de imagens) =====
IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/sua_conta

# ===== OpenRouter (IA pra editar emails) =====
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=google/gemini-2.5-flash
