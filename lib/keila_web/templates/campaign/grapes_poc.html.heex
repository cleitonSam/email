<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Editor Visual — {@campaign.subject || "Campanha"}</title>
  {csrf_meta_tag()}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- GrapesJS via CDN -->
  <link rel="stylesheet" href="https://unpkg.com/grapesjs@0.22.7/dist/css/grapes.min.css" />
  <script src="https://unpkg.com/grapesjs@0.22.7/dist/grapes.min.js"></script>
  <script src="https://unpkg.com/grapesjs-mjml@1.0.6"></script>

  <style>
    :root {
      --fluxo-500: #FF5A1F;
      --fluxo-400: #FF7B47;
      --fluxo-300: #FF9D75;
      --cyan-400: #22D3EE;
      --bg-900: #0A1F3D;
      --bg-800: #0F2848;
      --bg-700: #1A2F52;
      --bg-600: #243A5E;
      --border: rgba(255,255,255,0.08);
      --text: #F1F5F9;
      --text-muted: #94A3B8;
      --success: #4ADE80;
      --error: #F87171;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; background: var(--bg-900); color: var(--text); font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }

    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 10px 20px;
      background: linear-gradient(180deg, var(--bg-900), var(--bg-800));
      border-bottom: 1px solid var(--border);
      height: 60px;
      flex-shrink: 0;
    }
    .toolbar .left { display: flex; align-items: center; gap: 14px; min-width: 0; }
    .toolbar h1 { font-size: 14px; font-weight: 600; margin: 0; opacity: 0.95; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 360px; }
    .toolbar h1 small { display: block; font-size: 11px; opacity: 0.55; font-weight: 400; margin-top: 2px; }
    .badge {
      background: linear-gradient(135deg, var(--fluxo-500), var(--cyan-400));
      color: var(--bg-900);
      font-size: 10px;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: 999px;
      letter-spacing: 1px;
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .toolbar .actions { display: flex; align-items: center; gap: 10px; }

    .save-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      padding: 4px 12px;
      border-radius: 999px;
      transition: all 0.2s;
      opacity: 0;
    }
    .save-status.show { opacity: 1; }
    .save-status.saving { background: rgba(34,211,238,0.12); color: var(--cyan-400); }
    .save-status.saved { background: rgba(74,222,128,0.12); color: var(--success); }
    .save-status.error { background: rgba(248,113,113,0.12); color: var(--error); }
    .save-status .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }
    .save-status.saving .dot { animation: pulse 1.2s ease-in-out infinite; }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .btn {
      border: none;
      padding: 9px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.15s;
      font-family: inherit;
    }
    .btn-ghost { background: transparent; color: var(--text); opacity: 0.7; }
    .btn-ghost:hover { opacity: 1; background: rgba(255,255,255,0.06); }
    .btn-primary {
      background: linear-gradient(135deg, var(--fluxo-500), var(--cyan-400));
      color: var(--bg-900);
      box-shadow: 0 4px 12px rgba(255,90,31,0.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(255,90,31,0.35); }
    .btn-primary:disabled { opacity: 0.6; cursor: wait; transform: none; }

    #gjs-wrapper { flex: 1; min-height: 0; height: calc(100vh - 60px); }

    /* GrapesJS dark theme - override */
    .gjs-one-bg { background-color: var(--bg-800) !important; }
    .gjs-one-color, .gjs-one-color-h:hover { color: var(--text) !important; }
    .gjs-two-bg { background-color: var(--bg-700) !important; }
    .gjs-two-color, .gjs-two-color-h:hover { color: var(--text) !important; }
    .gjs-three-bg { background-color: var(--fluxo-500) !important; color: #fff !important; }
    .gjs-three-color, .gjs-three-color-h:hover { color: var(--fluxo-500) !important; }
    .gjs-four-bg { background-color: var(--bg-600) !important; }
    .gjs-four-color, .gjs-four-color-h:hover { color: var(--fluxo-500) !important; }
    .gjs-color-active, .gjs-color-active * { color: var(--fluxo-500) !important; }
    .gjs-block:hover { border-color: var(--fluxo-500) !important; }
    .gjs-block.gjs-bdrag { background: var(--fluxo-500) !important; }
    .gjs-pn-btn.gjs-pn-active { color: var(--fluxo-500) !important; }
    .gjs-cv-canvas { background-color: #1a2438 !important; }
  </style>
</head>
<body>
  <div class="toolbar">
    <div class="left">
      <span class="badge">Visual</span>
      <h1>
        {@campaign.subject || "(sem assunto)"}
        <small>Editor drag-and-drop</small>
      </h1>
    </div>
    <span id="save-status" class="save-status">
      <span class="dot"></span>
      <span class="text"></span>
    </span>
    <div class="actions">
      <a href={"/projects/" <> @current_project.id <> "/campaigns/" <> @campaign.id} class="btn btn-ghost">
        ← Voltar pra edição padrão
      </a>
      <button id="btn-save" class="btn btn-primary" type="button">
        Salvar agora
      </button>
    </div>
  </div>

  <div id="gjs-wrapper">
    <div id="gjs"></div>
  </div>

  <textarea id="initial-mjml" hidden><%= @initial_mjml || "<mjml><mj-body><mj-section><mj-column><mj-text>Olá!</mj-text></mj-column></mj-section></mj-body></mjml>" %></textarea>

  <script>
    (function() {
      const initialMjml = document.getElementById('initial-mjml').value;
      const projectId = <%= raw("\"#{@current_project.id}\"") %>;
      const campaignId = <%= raw("\"#{@campaign.id}\"") %>;
      const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
      const saveUrl = `/projects/${projectId}/campaigns/${campaignId}/grapes/save`;

      const editor = grapesjs.init({
        container: '#gjs',
        height: '100%',
        width: 'auto',
        storageManager: false,
        plugins: ['grapesjs-mjml'],
        pluginsOpts: { 'grapesjs-mjml': {} }
      });

      editor.on('load', () => {
        try {
          if (initialMjml && initialMjml.trim()) {
            editor.setComponents(initialMjml);
          }
        } catch (e) {
          console.error('Erro carregando MJML inicial:', e);
        }

        // Registra os 17 blocos do Fluxo no painel lateral do GrapesJS
        loadFluxoBlocks();
      });

      // ========= BLOCOS DO FLUXO =========
      async function loadFluxoBlocks() {
        try {
          const listResp = await fetch(`/projects/${projectId}/blocks/list.json`);
          const listData = await listResp.json();
          if (!listData.blocks) return;

          const bm = editor.BlockManager;

          // Categorias do Fluxo viram categorias do GrapesJS
          // Os blocos default do grapesjs-mjml ficam na "Basic". Os nossos ganham
          // categorias proprias com prefixo "Fluxo:" pra diferenciar visualmente.
          for (const block of listData.blocks) {
            // Lazy fetch do MJML no momento do drop seria ideal, mas BlockManager
            // do GrapesJS espera content sincrono. Fazemos prefetch leve em paralelo.
            try {
              const snippetResp = await fetch(`/projects/${projectId}/blocks/snippet/${block.slug}`);
              const snippetData = await snippetResp.json();
              if (!snippetData.mjml) continue;

              bm.add('fluxo-' + block.slug, {
                label: `${block.icon} ${block.title}`,
                category: 'Fluxo: ' + block.category,
                content: snippetData.mjml,
                attributes: { title: block.description }
              });
            } catch (e) {
              console.warn('Falha pré-carregando bloco', block.slug, e);
            }
          }

          // Abre o painel de blocos por default depois de carregar
          const panel = editor.Panels.getButton('views', 'open-blocks');
          if (panel) panel.set('active', true);
        } catch (e) {
          console.error('Falha carregando blocos do Fluxo:', e);
        }
      }

      // ========= STATUS UI =========
      const statusEl = document.getElementById('save-status');
      const statusText = statusEl.querySelector('.text');
      let statusTimer = null;
      function setStatus(state, msg) {
        clearTimeout(statusTimer);
        statusEl.className = 'save-status show ' + state;
        statusText.textContent = msg;
        if (state === 'saved') {
          statusTimer = setTimeout(() => { statusEl.className = 'save-status'; }, 2500);
        }
      }

      // ========= SAVE =========
      const btnSave = document.getElementById('btn-save');
      let saving = false;
      let pendingSave = false;

      async function doSave() {
        if (saving) { pendingSave = true; return; }
        const mjml = editor.getHtml();
        if (!mjml || mjml.length < 20) return;

        saving = true;
        setStatus('saving', 'Salvando...');
        btnSave.disabled = true;

        try {
          const resp = await fetch(saveUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'x-csrf-token': csrfToken,
              'Accept': 'application/json'
            },
            body: JSON.stringify({ mjml: mjml })
          });
          const data = await resp.json();

          if (resp.ok && data.ok) {
            setStatus('saved', 'Salvo');
          } else {
            setStatus('error', 'Erro: ' + (data.errors || resp.statusText));
          }
        } catch (e) {
          console.error(e);
          setStatus('error', 'Erro de rede');
        } finally {
          saving = false;
          btnSave.disabled = false;
          if (pendingSave) {
            pendingSave = false;
            setTimeout(doSave, 100);
          }
        }
      }

      // Save manual (botão / Ctrl+S)
      btnSave.addEventListener('click', doSave);
      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
          e.preventDefault();
          doSave();
        }
      });

      // ========= AUTO-SAVE =========
      // Debounce 2s após qualquer mudança no canvas
      let autoSaveTimer = null;
      function scheduleAutoSave() {
        clearTimeout(autoSaveTimer);
        autoSaveTimer = setTimeout(doSave, 2000);
      }

      // Eventos do GrapesJS que indicam mudança real
      editor.on('component:add component:remove component:update:components component:update:attributes component:update:content style:update', scheduleAutoSave);

      // Aviso antes de fechar se ainda tem auto-save pendente
      window.addEventListener('beforeunload', (e) => {
        if (saving || autoSaveTimer) {
          e.preventDefault();
          e.returnValue = '';
        }
      });
    })();
  </script>
</body>
</html>
